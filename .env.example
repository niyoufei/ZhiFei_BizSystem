# 复制为 .env 后按需填写（不要提交 .env 到版本库）

# 服务端口（默认 8000）；若被占用可改为 8080 等
# PORT=8000

# API 认证：多个 key 用逗号分隔；不设置则开发模式（不校验）
# API_KEYS=your-secret-key-1,your-secret-key-2

# 历史星火兼容配置（默认不再使用）
# 若仍需兼容旧 CLI spark 别名，可保留下列配置；当前默认已切到 OpenAI GPT-5.4
# SPARK_APIPASSWORD=your-spark-apipassword

# 学习进化 LLM 后端：rules（仅规则）| spark | openai | gemini
# 设为 openai 并配置 OPENAI_API_KEY 后，进化报告会由 OpenAI GPT-5.4 增强（高分逻辑与编制指导）
# 默认推荐模型：OpenAI gpt-5.4、Gemini gemini-1.5-pro、星火 4.0Ultra
# 可通过 OPENAI_MODEL / GEMINI_MODEL / SPARK_MODEL 覆盖（如 SPARK_MODEL=generalv3.5）
# EVOLUTION_LLM_BACKEND=openai
# OPENAI_API_KEY=your-openai-key
# OPENAI_MODEL=gpt-5.4
# GEMINI_API_KEY=your-gemini-key
# GEMINI_MODEL=gemini-1.5-pro
# SPARK_MODEL=4.0Ultra

# 限流（可选）
# RATE_LIMIT_ENABLED=true
# RATE_LIMIT_DEFAULT=100/minute
# RATE_LIMIT_SCORE=30/minute
# RATE_LIMIT_UPLOAD=20/minute
