HOST=127.0.0.1
PORT=8000
PYTHONUNBUFFERED=1
ZHIFEI_PRODUCTION_MODE=1
ZHIFEI_ALLOWED_HOSTS=bid.niyoufei.com
ZHIFEI_MAX_UPLOAD_MB=64
ZHIFEI_REQUIRE_API_KEYS=1
ZHIFEI_DATA_DIR=/var/lib/zhifei-bid/data

# Fill these before production use.
# API_KEYS=replace-with-admin-api-key
# OPENAI_API_KEY=replace-with-openai-key
# SPARK_APIPASSWORD=replace-with-spark-password
